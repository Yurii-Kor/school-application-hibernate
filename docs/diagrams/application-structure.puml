@startuml
allowmixing

title School Application Hibernate - Application Structure Overview

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 12
}
hide stereotype

top to bottom direction

rectangle "Spring Boot Entry Point\n\nSchoolApplicationConsole\n\nStarts the application\nand creates the Spring context" as app

rectangle "Console UI\n\nMainMenu\nMenuActions\n\nReads user input and delegates\nselected menu actions" as ui

rectangle "Service Layer\n\nViewDaoService\n\nCoordinates console actions\nand persistence operations" as service

rectangle "DAO Layer\n\nDao\nStudentDao\nCourseDao\nGroupDao\n\nUses EntityManager for\nCRUD and custom queries" as dao

rectangle "Hibernate / JPA Infrastructure\n\nEntityManager\nPersistence Context\nTransactions\nBean Validation\n\nManages entity state,\nrelations, validation,\nand database operations" as jpa

rectangle "JPA Entity Model\n\nStudent\nGroup\nCourse\n\nMaps Java objects to\nrelational database tables" as domain

rectangle "Entity Relationships\n\nGroup 1 → many Students\nStudent many ↔ many Courses\n\nRepresented through\nJPA annotations" as relations

rectangle "Configuration\n\nScannerConfig\nValidatorConfig\nSpring Boot properties\nFlyway migrations\n\nProvides console input,\nvalidation, datasource,\nand schema setup" as config

database "PostgreSQL\n\nTables:\ngroups\nstudents\ncourses\nstudents_courses" as db

app --> ui : starts
ui --> service : delegates commands
service --> dao : calls persistence logic
dao --> jpa : uses
jpa --> db : SQL generated by Hibernate
dao --> domain : persists and queries entities
domain --> relations : defines mappings
config --> ui : provides Scanner
config --> jpa : provides validation and persistence setup

note left of jpa
This project replaces manual JDBC row mapping
with Hibernate/JPA entity management.

SQL tables remain visible through migrations,
but persistence operations work with entities
and relationships instead of manual ResultSet mapping.
end note

@enduml
